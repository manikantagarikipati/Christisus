<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/tvClasstName"
        tools:text="Class X"
        android:ellipsize="end"
        android:textSize="22sp"
        android:maxLength="24"
        android:width="200dp"
        android:paddingHorizontal="16dp"
        android:layout_marginHorizontal="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <androidx.appcompat.widget.AppCompatSpinner
        android:id="@+id/spinnerProfile1"
        android:textSize="18sp"
        android:width="120dp"
        android:maxLines="2"
        android:entries="@array/profile_names_1"
        android:layout_marginHorizontal="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvClasstName"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <androidx.appcompat.widget.AppCompatSpinner
        android:id="@+id/spinnerProfile2"
        android:textSize="18sp"
        android:width="120dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:entries="@array/profile_names_2"
        android:layout_marginHorizontal="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvClasstName"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <androidx.appcompat.widget.AppCompatSpinner
        android:id="@+id/spinnerProfile3"
        android:textSize="18sp"
        android:width="120dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginHorizontal="8dp"
        android:entries="@array/profile_names_3"
        app:layout_constraintTop_toBottomOf="@id/tvClasstName"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <androidx.appcompat.widget.AppCompatSpinner
        android:id="@+id/language_spinner"
        android:textSize="18sp"
        android:width="120dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:entries="@array/language_entries"
        android:layout_marginHorizontal="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvClasstName"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>
